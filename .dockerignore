# =============================================================================
# .dockerignore — keeps the build context small and reproducible.
# Anything matched here is NOT sent to the Docker daemon / ACR.
# =============================================================================

# VCS & CI
.git
.gitignore
.gitattributes
.github

# Editor / OS noise
.vscode
.idea
.DS_Store
Thumbs.db

# Local secrets — NEVER ship .env into the image. App Settings provide them.
.env
.env.*
**/.env
**/.env.*

# Local node_modules — the build stage runs `pnpm install` cleanly.
**/node_modules

# Local build outputs — the build stage regenerates these.
**/dist
**/build
**/.turbo
**/.cache
**/.next
**/.vite
**/.parcel-cache
**/.expo
**/.expo-shared
**/tsconfig.tsbuildinfo
**/*.tsbuildinfo

# Logs / coverage / temp
**/*.log
**/coverage
**/tmp
**/out-tsc

# Replit local state
.cache
.local
.upm
.replit

# Python venv that the repo sometimes carries (not needed)
MYENV

# Misc large attachments not needed at runtime
attached_assets

# Previously created release artifact from the github actions workflow
release.zip

# Docker config files themselves (already on the daemon)
Dockerfile
.dockerignore

# User data that should be mounted as a volume in production, NOT baked in
artifacts/api-server/data/documents
